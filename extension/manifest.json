{
  "manifest_version": 3,
  "name": "Slock Clipper",
  "description": "Clip webpages, URLs, and selected text into Slock channels through a local relay.",
  "version": "0.1.0",
  "action": {
    "default_title": "Slock Clipper",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "contextMenus", "storage", "notifications", "scripting"],
  "host_permissions": ["http://127.0.0.1:9321/*"]
}
